# SQLAlchemy Database URI for MySQL
# Format: mysql+pymysql://<user>:<password>@<host>:<port>/<database>
DATABASE_URI="mysql+pymysql://root:password@localhost:3306/mydatabase"

# Ollama LLM model to use for SQL generation and analysis
LLM_MODEL="llama3"

# Sentence Transformer model for creating vector embeddings
EMBEDDING_MODEL="mxbai-embed-large"

# Default limit for rows returned by a SQL query
SQL_AUTO_LIMIT=100
